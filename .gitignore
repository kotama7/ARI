# ===========================
# ARI root-level .gitignore
# ===========================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build/
.env
*.egg

# ── Experiment artifacts (NEVER track) ─────────────────────────
# SLURM job logs & error files
logs/
*.out
*.err
slurm-*.out

# Checkpoint directories (generated at runtime)
*_ckpt_*/
checkpoints/
output*/
results*/

# Experiment-specific source files (user-created, not part of ARI)
experiments/
benchmarks/
*.c
*.f90
*.def
*.sbatch

# Dynamic YAML/scripts generated per-experiment
*_paper.yaml
*_paper.sh
*_experiment.sh

# ── Security ────────────────────────────────────────────────────
.env
*.env.local
*.key
*.pem
*.token

# ── Editor / OS ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Additional experiment/runtime directories ────────────────────
containers/
report/
workspace/
*.sif

# Temporary work files
audit_prompt.txt
fix_*.py
new_server.py


# Reproducibility check outputs
ari-core/repro_*/
ari-core/work_dir/
ari-core/out_*.csv
ari-core/experiments/
ari-core/checkpoints/

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
.eggs/
dist/
build/
