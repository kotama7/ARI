# ===========================
# ARI root-level .gitignore
# ===========================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build/
.env
*.egg

# ── Experiment artifacts (NEVER track) ─────────────────────────
# SLURM job logs & error files
logs/
*.out
*.err
slurm-*.out

# Checkpoint directories (generated at runtime)
*_ckpt_*/
checkpoints/
output*/
results*/

# Experiment-specific source files (user-created, not part of ARI)
experiments/
benchmarks/
*.c
*.cpp
*.f90
*.def
*.sbatch

# Dynamic YAML/scripts generated per-experiment
*_paper.yaml
*_paper.sh
*_experiment.sh

# ── Setup artifacts (environment-specific) ─────────────────────
.ari_python

# ── Security ────────────────────────────────────────────────────
.env
*.env.local
*.key
*.pem
*.token

# ── Editor / OS ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Additional experiment/runtime directories ────────────────────
# Container images are large runtime artifacts; ignore the contents but
# keep the directories documented (their README.md is tracked).
/containers/*
!/containers/README.md
/ari-core/containers/*
!/ari-core/containers/README.md
workspace/
*.sif

# Temporary work files
audit_prompt.txt
fix_*.py
new_server.py


# Reproducibility check outputs
ari-core/repro_*/
ari-core/work_dir/
ari-core/out_*.csv
ari-core/experiments/
ari-core/checkpoints/

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
.eggs/
dist/
build/

# ── Runtime / temp files (generated at runtime, never track) ────
experiment.md
ari-core/experiment.md
tmp*.md
GUI_TASK.md
*_TASK.md

# ── Backup directories ──────────────────────────────────────────
*.bak/
viz.bak/

# ── Virtual environments ───────────────────────────────────────
.venv/
venv/

# ── Node / Frontend ───────────────────────────────────────────
node_modules/
ari-core/ari/viz/frontend/node_modules/
ari-core/ari/viz/static/dist/

# ── Compiled binaries (experiment artifacts) ───────────────────
*.out

# ── AI session artifacts ────────────────────────────────────────
HEARTBEAT.md
# Runtime memory stores (AI session artifacts), but not the source package.
memory/
!ari-core/ari/memory/

# ── External research artifacts (never commit) ─────────────────
# Local-only PDFs used as test inputs / research plans. References in
# ARI source/docs use abstract names ("HPC PaperBench audit research
# plan", DOI placeholders) so the repo stays usable without these
# files; ignore them here so they cannot be accidentally staged.
/HPC_PaperBench_Final_Proposal_for_Professors.pdf
/SC41406.2024.*.pdf
