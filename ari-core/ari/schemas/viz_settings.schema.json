{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ari/schemas/viz_settings.schema.json",
  "title": "ARI dashboard Settings (GET /api/settings)",
  "description": "Response of GET /api/settings (api_settings._api_get_settings, line 119), a {**defaults, **saved} merge, and the flat object POSTed back to POST /api/settings. Mirrors frontend/src/types/index.ts Settings (lines 38-75). additionalProperties:true encodes the saved-key passthrough (test_api_schema_contract.py:101-108). 'required' lists exactly the defaults asserted always-present by test_api_schema_contract.py:89-98. NOTE 'ors' (an object carrying judge_model) is emitted by the backend but is NOT declared in the Settings TS interface — a documented drift kept in properties (not required) so the TS<->schema sync test does not fail on it.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "llm_model",
    "llm_provider",
    "ollama_host",
    "temperature",
    "retrieval_backend",
    "slurm_partition",
    "slurm_walltime",
    "container_mode",
    "container_pull",
    "vlm_review_enabled",
    "vlm_review_model",
    "letta_base_url",
    "letta_embedding_config"
  ],
  "properties": {
    "llm_model": {"type": "string"},
    "llm_provider": {"type": "string"},
    "llm_backend": {"type": "string"},
    "llm_api_key": {"type": "string"},
    "ollama_host": {"type": "string"},
    "llm_base_url": {"type": "string"},
    "temperature": {"type": "number"},
    "semantic_scholar_key": {"type": "string"},
    "retrieval_backend": {"type": "string"},
    "ssh_host": {"type": "string"},
    "ssh_port": {"type": "integer"},
    "ssh_user": {"type": "string"},
    "ssh_path": {"type": "string"},
    "ssh_key": {"type": "string"},
    "slurm_partition": {"type": "string"},
    "slurm_partitions": {"type": "array", "items": {"type": "string"}},
    "slurm_cpus": {"type": "integer"},
    "slurm_memory_gb": {"type": "integer"},
    "slurm_walltime": {"type": "string"},
    "language": {"type": "string"},
    "model_idea": {"type": "string"},
    "model_bfts": {"type": "string"},
    "model_coding": {"type": "string"},
    "model_eval": {"type": "string"},
    "model_paper": {"type": "string"},
    "model_review": {"type": "string"},
    "container_mode": {"type": "string"},
    "container_image": {"type": "string"},
    "container_pull": {"type": "string"},
    "vlm_review_enabled": {"type": "boolean"},
    "vlm_review_model": {"type": "string"},
    "vlm_review_max_iter": {"type": "integer"},
    "vlm_review_threshold": {"type": "number"},
    "letta_base_url": {"type": "string"},
    "letta_api_key": {"type": "string"},
    "letta_embedding_config": {"type": "string"},
    "ors": {
      "type": "object",
      "description": "Object-review-service settings; emitted by the backend (always includes judge_model) but not declared in the Settings TS interface.",
      "properties": {"judge_model": {"type": "string"}}
    }
  }
}
