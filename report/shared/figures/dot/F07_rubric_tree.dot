  c0l1 [shape=ellipse, label="structure"];
  c0 -> c0l1;
  c0l2 [shape=ellipse, label="language"];
  c0 -> c0l2;
  c1 [label="novelty\nw=0.20"];
  root -> c1;
  c1l0 [shape=ellipse, label="idea"];
  c1 -> c1l0;
  c1l1 [shape=ellipse, label="comparison"];
  c1 -> c1l1;
  c2 [label="rigor\nw=0.30"];
  root -> c2;
  c2l0 [shape=ellipse, label="theory"];
  c2 -> c2l0;
  c2l1 [shape=ellipse, label="experiments"];
  c2 -> c2l1;
  c2l2 [shape=ellipse, label="ablation"];
  c2 -> c2l2;
  c3 [label="impact\nw=0.20"];
  root -> c3;
  c3l0 [shape=ellipse, label="scope"];
